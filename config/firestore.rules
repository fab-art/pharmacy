rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow read/write if the user is authenticated and has an @rssb.rw email
    function isRSSB() {
      return request.auth != null && request.auth.token.email.endsWith('@rssb.rw');
    }

    match /referrals/{referralId} {
      allow read, write: if isRSSB();
    }

    match /cases/{caseId} {
      allow read, write: if isRSSB();
      // Allow pharmacy to read their specific case if they have a valid token
      // (This would be more complex in a real implementation)
      allow read: if request.auth != null;
    }

    match /vouchers/{voucherId} {
      allow read, write: if isRSSB();
    }

    match /rules/{ruleId} {
      allow read: if isRSSB();
      allow write: if isRSSB() && request.auth.token.role == 'admin';
    }

    match /audit_log/{logId} {
      allow create: if request.auth != null;
      allow read: if isRSSB() && request.auth.token.role == 'admin';
    }
  }
}
